dom\";\r\nimport profile_pic from '../resources/projects thumbnails/profile_pic.png'\r\nconst AboutMe=()=> {\r\n  return (\r\n    <div className=\"AboutMe\">\r\n      <div className=\"greetings\">\r\n        <h1 className=\"hello\">HELLO</h1>\r\n        <h1 className=\"name\">I'M DUY</h1>\r\n        <p className=\"info\">I am a student graduated from Queen Mary University of London. I have a passion in developing interfaces and designs for web applications.</p>\r\n      </div>\r\n      <div className=\"profile_pic\">\r\n        <img src={profile_pic}/>\r\n      </div>\r\n    \r\n    </div>\r\n  );\r\n}\r\n\r\nexport default AboutMe;\r\n","C:\\Users\\chila\\OneDrive\\Desktop\\Projects\\Portfolio\\portfolio-main\\src\\pages\\project.js",[],"C:\\Users\\chila\\OneDrive\\Desktop\\Projects\\Portfolio\\portfolio-main\\src\\pages\\project_card.js",["54","55"],"// CSS\r\nimport '../css/project_card.css';\r\n//image\r\nimport artist from '../resources/projects thumbnails/artist.jpg'\r\nconst ProjectCard=(props)=> {\r\n  return (\r\n    <div className=\"Project_card\">\r\n      <a className=\"link-wrapper\" href={props.link}>\r\n        <div className=\"image\">\r\n            <img src={props.cover}/>   \r\n        </div>\r\n      </a>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default ProjectCard;\r\n","C:\\Users\\chila\\OneDrive\\Desktop\\Projects\\Portfolio\\portfolio-main\\src\\pages\\skillsMeter.js",[],"C:\\Users\\chila\\OneDrive\\Desktop\\Projects\\Portfolio\\portfolio-main\\src\\pages\\Resume.js",["56","57","58"],"// CSS\r\nimport '../css/Resume.css';\r\n//Image\r\nimport page_1 from '../resources/Cv_page1.jpg'\r\nimport page_2 from '../resources/Cv_page2.jpg'\r\nimport { useState } from 'react';\r\nconst Resume=()=> {\r\n    const [page_no_1,setPage] = useState(true)\r\n    const changePage = ()=>{\r\n        setPage(!page_no_1)\r\n    }\r\n    return (\r\n    <div className=\"Resume\">\r\n       <div className=\"content\">\r\n           { page_no_1== true?(<img onClick=